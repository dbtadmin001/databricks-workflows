{
  "datasets": [
    {
      "name": "ds_daily_revenue",
      "displayName": "Daily Revenue",
      "queryLines": [
        "SELECT\n",
        "  transaction_date,\n",
        "  SUM(total_revenue) AS daily_revenue,\n",
        "  SUM(transaction_count) AS daily_transactions\n",
        "FROM\n",
        "  workspace.default.gold_daily_revenue\n",
        "GROUP BY\n",
        "  transaction_date\n",
        "ORDER BY\n",
        "  transaction_date"
      ]
    },
    {
      "name": "ds_product_revenue",
      "displayName": "Product Revenue",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  total_revenue,\n",
        "  ROUND(revenue_share * 100, 2) AS revenue_share_pct\n",
        "FROM\n",
        "  workspace.default.gold_product_performance\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ]
    },
    {
      "name": "ds_kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT transactionID) AS total_transactions,\n",
        "  COUNT(DISTINCT customerID) AS unique_customers,\n",
        "  COUNT(DISTINCT franchiseID) AS active_franchises,\n",
        "  ROUND(SUM(totalPrice), 2) AS total_revenue,\n",
        "  ROUND(AVG(totalPrice), 2) AS avg_basket_size\n",
        "FROM\n",
        "  workspace.default.silver_transactions_enriched"
      ]
    },
    {
      "name": "ds_payment_mix",
      "displayName": "Payment Method Mix",
      "queryLines": [
        "SELECT\n",
        "  paymentMethod,\n",
        "  COUNT(*) AS transaction_count,\n",
        "  ROUND(SUM(totalPrice), 2) AS total_revenue\n",
        "FROM\n",
        "  workspace.default.silver_transactions_enriched\n",
        "GROUP BY\n",
        "  paymentMethod\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ]
    },
    {
      "name": "ds_franchise_top20",
      "displayName": "Top 20 Franchises",
      "queryLines": [
        "SELECT\n",
        "  revenue_rank,\n",
        "  franchise_name,\n",
        "  city,\n",
        "  country,\n",
        "  store_size,\n",
        "  total_revenue,\n",
        "  transaction_count,\n",
        "  unique_customers,\n",
        "  avg_basket_size\n",
        "FROM\n",
        "  workspace.default.gold_franchise_ranking\n",
        "ORDER BY\n",
        "  revenue_rank\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "ds_spend_tiers",
      "displayName": "Customer Spend Tiers",
      "queryLines": [
        "SELECT\n",
        "  spend_tier,\n",
        "  COUNT(customerID) AS customer_count,\n",
        "  ROUND(AVG(total_spend), 2) AS avg_spend,\n",
        "  ROUND(AVG(visit_count), 1) AS avg_visits\n",
        "FROM\n",
        "  workspace.default.gold_customer_segments\n",
        "GROUP BY\n",
        "  spend_tier\n",
        "ORDER BY\n",
        "  avg_spend DESC"
      ]
    },
    {
      "name": "ds_fav_products",
      "displayName": "Favourite Products by Gender",
      "queryLines": [
        "SELECT\n",
        "  gender,\n",
        "  favourite_product,\n",
        "  COUNT(*) AS customer_count\n",
        "FROM\n",
        "  workspace.default.gold_customer_segments\n",
        "GROUP BY\n",
        "  gender,\n",
        "  favourite_product\n",
        "ORDER BY\n",
        "  gender,\n",
        "  customer_count DESC"
      ]
    },
    {
      "name": "ds_hourly",
      "displayName": "Hourly Sales",
      "queryLines": [
        "SELECT\n",
        "  transaction_hour,\n",
        "  COUNT(transactionID) AS transaction_count,\n",
        "  ROUND(AVG(totalPrice), 2) AS avg_basket_size\n",
        "FROM\n",
        "  workspace.default.silver_transactions_enriched\n",
        "GROUP BY\n",
        "  transaction_hour\n",
        "ORDER BY\n",
        "  transaction_hour"
      ]
    },
    {
      "name": "ds_store_size",
      "displayName": "Revenue by Store Size",
      "queryLines": [
        "SELECT\n",
        "  store_size,\n",
        "  SUM(total_revenue) AS total_revenue,\n",
        "  COUNT(DISTINCT franchiseID) AS store_count\n",
        "FROM\n",
        "  workspace.default.gold_franchise_ranking\n",
        "GROUP BY\n",
        "  store_size\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ]
    },
    {
      "name": "ds_country_revenue",
      "displayName": "Revenue by Country",
      "queryLines": [
        "SELECT\n",
        "  country,\n",
        "  SUM(total_revenue) AS total_revenue,\n",
        "  COUNT(DISTINCT franchiseID) AS franchise_count\n",
        "FROM\n",
        "  workspace.default.gold_franchise_ranking\n",
        "GROUP BY\n",
        "  country\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ]
    }
  ],
